# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# R
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.rds

# macOS cruft
.DS_Store
__MACOSX/

# Default: ignore large data files everywhere
*.csv
*.xlsx

# ── Plans: track all plan data, config, and baselines ──
!plans/**/*.csv
!plans/**/*.json

# Memory bank (local notes, not for git)
memory-bank/

# Actuarial calculations — track reference materials, ignore large/scratch files
actuarial_calculations/convert_doc.py
actuarial_calculations/Winklevoss - 1993 - Pension mathematics with numerical illustrations.pdf

# R model source projects (copied manually per environment)
R_model/R_model_*/

# Temp/output
output/
mathpix_output/

# Scratch scripts (throwaway work; promote before committing)
scripts/scratch/*
!scripts/scratch/.gitkeep
